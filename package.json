{
  "name": "rsvp-reader",
  "version": "0.1.0",
  "description": "RSVP speed-reading for Obsidian, with an optional voice narrator synced to the words.",
  "type": "module",
  "license": "MIT",
  "author": "Kevin Lin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinsslin/obsidian-rsvp-reader.git"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "rsvp",
    "speed-reading",
    "spritz",
    "text-to-speech"
  ],
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run typecheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:demo": "esbuild demo/demo.ts --bundle --format=iife --target=es2020 --outfile=demo/demo.bundle.js",
    "smoke": "node scripts/load-smoke.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run smoke",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "devDependencies": {
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^3.2.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.15.0",
    "jsdom": "^25.0.1",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.16.0",
    "vitest": "^3.2.0"
  }
}
